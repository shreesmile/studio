{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Enterprise user profile with hierarchical status.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Super Admin", "Admin", "Manager", "Team Lead", "Employee"] },
        "department": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Pending", "Blocked"] },
        "managerId": { "type": "string" },
        "teamLeadId": { "type": "string" },
        "password": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role", "status", "department"]
    },
    "Project": {
      "title": "Project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
        "status": { "type": "string", "enum": ["Not Started", "In Progress", "Completed", "On Hold"] },
        "assignedTo": { "type": "array", "items": { "type": "string" }, "description": "Array of UIDs assigned to this project." },
        "department": { "type": "string" },
        "createdBy": { "type": "string" }
      },
      "required": ["name", "status", "priority", "department"]
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedTo": { "type": "string" },
        "createdBy": { "type": "string" },
        "dueDate": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed", "blocked"] },
        "estimatedHours": { "type": "number" },
        "assignedToDepartment": { "type": "string" }
      },
      "required": ["projectId", "title", "assignedTo", "status"]
    },
    "SubTask": {
      "title": "SubTask",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "taskId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "createdBy": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] }
      },
      "required": ["taskId", "title", "status"]
    },
    "WorkLog": {
      "title": "WorkLog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "projectId": { "type": "string" },
        "taskId": { "type": "string" },
        "subTaskId": { "type": "string" },
        "date": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "totalHours": { "type": "number" },
        "progressNote": { "type": "string" },
        "department": { "type": "string" }
      },
      "required": ["userId", "date", "totalHours", "progressNote"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Central user directory."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Organizational projects."
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Main workflow tasks."
    },
    "/sub_tasks/{subTaskId}": {
      "schema": { "$ref": "#/entities/SubTask" },
      "description": "Granular task units."
    },
    "/work_logs/{logId}": {
      "schema": { "$ref": "#/entities/WorkLog" },
      "description": "Daily work tracking logs."
    }
  }
}