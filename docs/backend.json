{
  "entities": {
    "Role": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Role",
      "type": "object",
      "description": "Defines the distinct roles within the application.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "description", "permissions"]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an individual user account.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["Super Admin", "Admin", "Manager", "Team Lead", "Employee"] },
        "department": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role", "password", "department", "createdAt", "updatedAt"]
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "description": "Represents a trackable task.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed", "blocked"] },
        "deadline": { "type": "string" },
        "assignedToId": { "type": "string" },
        "assignedToRole": { "type": "string" },
        "assignedToDepartment": { "type": "string" },
        "assignedById": { "type": "string" },
        "assignedByRole": { "type": "string" },
        "assignedByName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "description", "status", "assignedToId", "assignedById", "assignedByRole", "assignedToRole", "assignedToDepartment", "createdAt", "updatedAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Primary user profile storage."
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Centralized task board documents."
    },
    "/user_roles_{role}/{userId}": {
      "schema": { "type": "object" },
      "description": "Hierarchy check markers for security rules."
    }
  }
}
