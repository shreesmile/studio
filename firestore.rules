rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES
     * Optimized for Role-Based Access Control (RBAC).
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role Checks (DBAC Pattern with Profile Fallback)
    // We check for document existence in role collections OR fallback to the role field in the user profile.
    function hasRole(roleName) {
      let roleDoc = roleName.lower().replace(" ", "_");
      return isSignedIn() && (
        exists(/databases/$(database)/documents/user_roles_$(roleDoc)/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == roleName)
      );
    }

    function isSuperAdmin() {
      return hasRole('Super Admin');
    }

    function isAdmin() {
      return isSuperAdmin() || hasRole('Admin');
    }

    function isManager() {
      return isAdmin() || hasRole('Manager');
    }

    function isTeamLead() {
      return isManager() || hasRole('Team Lead');
    }

    // --- COLLECTION RULES ---

    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /departments/{departmentId} {
      allow get, list: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /users/{userId} {
      // Allow user to read/create/update their OWN profile
      // Allow Admins to manage ALL profiles
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isSignedIn();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isSuperAdmin();
    }

    // Role Assignment Collections (DBAC)
    // Allow users to write their OWN role document (essential for registration)
    // Allow Admins to manage others' roles
    match /user_roles_super_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isSuperAdmin(); 
    }
    match /user_roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isSuperAdmin();
    }
    match /user_roles_manager/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }
    match /user_roles_team_lead/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isManager();
    }
    match /user_roles_employee/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isTeamLead();
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin() || (resource != null && resource.data.assignedById == request.auth.uid);
    }
  }
}