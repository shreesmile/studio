rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPERS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role markers are stored in collections named user_roles_Role_Name
    // We sanitize the role name to match the collection naming convention
    function hasRole(role) {
      return exists(/databases/$(database)/documents/user_roles_$(role.replace(' ', '_'))/$(request.auth.uid));
    }

    function getRoleLevel(role) {
      let r = role.lower();
      return r == 'super admin' ? 4 :
             r == 'admin' ? 3 :
             r == 'manager' ? 2 :
             r == 'team lead' ? 1 : 0;
    }

    function getMyLevel() {
      let data = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return getRoleLevel(data.role);
    }

    function canManageTarget(targetRole) {
      return isSignedIn() && getMyLevel() > getRoleLevel(targetRole);
    }

    // --- RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && getMyLevel() >= 1; // Team Lead+ can view directory
      
      // Allow registration or creation by superiors
      allow create: if isSignedIn() && (isOwner(userId) || canManageTarget(request.resource.data.role));
      
      // Allow update if owner (but role must stay same) OR if superior
      allow update: if isSignedIn() && (
        (isOwner(userId) && request.resource.data.role == resource.data.role) || 
        canManageTarget(resource.data.role)
      );
      
      allow delete: if isSignedIn() && canManageTarget(resource.data.role);
    }

    match /tasks/{taskId} {
      function myDept() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department;
      }

      allow read: if isSignedIn() && (
        getMyLevel() >= 3 || // Admin+ can see all
        (getMyLevel() >= 1 && resource.data.assignedToDepartment == myDept()) || // Team Lead+ see team
        resource.data.assignedToId == request.auth.uid // Employee sees own
      );

      allow create: if isSignedIn() && (
        getMyLevel() >= 3 || // Admin+
        (getMyLevel() >= 1 && canManageTarget(request.resource.data.assignedToRole)) // Team Lead+ assign to subordinates
      );

      allow update: if isSignedIn() && (
        getMyLevel() >= 3 || 
        resource.data.assignedToId == request.auth.uid ||
        resource.data.assignedById == request.auth.uid
      );

      allow delete: if isSignedIn() && getMyLevel() >= 3;
    }

    // Helper collections for role indexing
    match /user_roles_{role}/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && getMyLevel() >= 3; // Admins manage role index
    }
  }
}
