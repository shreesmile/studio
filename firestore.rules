rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES - ROBUST RBAC HIERARCHY
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasRole(roleName) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/user_roles_$(roleName.toLower().replace(" ", "_"))/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == roleName)
      );
    }

    function isSuperAdmin() { return hasRole('Super Admin'); }
    function isAdmin() { return isSuperAdmin() || hasRole('Admin'); }
    function isManager() { return isAdmin() || hasRole('Manager'); }
    function isTeamLead() { return isManager() || hasRole('Team Lead'); }

    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isTeamLead());
      allow list: if isTeamLead();
      
      allow create: if isSignedIn(); // Handled by UI/Existence checks
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isSignedIn() && isAdmin();
    }

    match /tasks/{taskId} {
      function canViewTask(taskData) {
        let profile = getProfile();
        return isSuperAdmin() ||
               (isAdmin() && taskData.assignedByRole != 'Super Admin') ||
               (isManager() && taskData.assignedToDepartment == profile.department) ||
               (isTeamLead() && taskData.assignedToDepartment == profile.department) ||
               (taskData.assignedToId == request.auth.uid);
      }

      allow read: if isSignedIn() && canViewTask(resource.data);
      
      allow create: if isSignedIn() && (
        isSuperAdmin() || 
        (isAdmin() && request.resource.data.assignedToRole in ['Manager', 'Team Lead', 'Employee']) ||
        (isManager() && request.resource.data.assignedToRole in ['Team Lead', 'Employee']) ||
        (isTeamLead() && request.resource.data.assignedToRole == 'Employee')
      );
      
      allow update: if isSignedIn() && (
        isSuperAdmin() || 
        (resource.data.assignedToId == request.auth.uid) || 
        (isAdmin() && resource.data.assignedByRole != 'Super Admin') ||
        (isTeamLead() && resource.data.assignedToDepartment == getProfile().department)
      );
      
      allow delete: if isSignedIn() && (isSuperAdmin() || (isAdmin() && resource.data.assignedByRole != 'Super Admin'));
    }

    // Role Assignment Collections (DBAC)
    match /user_roles_super_admin/{userId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
    match /user_roles_admin/{userId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
    match /user_roles_manager/{userId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /user_roles_team_lead/{userId} { allow read: if isSignedIn(); allow write: if isManager(); }
    match /user_roles_employee/{userId} { allow read: if isSignedIn(); allow write: if isTeamLead(); }

    match /roles/{roleId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
    match /departments/{departmentId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
  }
}