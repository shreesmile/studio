
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------
    // Helper Functions
    // -------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function getRole() {
      let data = getUserData();
      return data != null ? data.role : "None";
    }

    function getRoleWeight(role) {
      return role == "Super Admin" ? 5 :
             role == "Admin" ? 4 :
             role == "Manager" ? 3 :
             role == "Team Lead" ? 2 : 
             role == "Employee" ? 1 : 0;
    }

    function getWeight() {
      return getRoleWeight(getRole());
    }

    function isMyDept(dept) {
      let data = getUserData();
      return data != null && data.department == dept;
    }

    // -------------------------
    // USERS
    // -------------------------

    match /users/{userId} {
      allow get: if isSignedIn();
      // Super Admin/Admin see all. Manager/TL see department.
      allow list: if isSignedIn() && (getWeight() >= 4 || (getWeight() >= 2 && isMyDept(resource.data.department)));
      
      // Allow creation if Admin+ OR if Manager/TL creating a subordinate in their department
      allow create: if isSignedIn() && (
        request.auth.uid == userId || 
        getWeight() >= 4 || 
        (getWeight() >= 2 && isMyDept(request.resource.data.department) && getWeight() > getRoleWeight(request.resource.data.role))
      );
      
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        getWeight() >= 4 || 
        (getWeight() >= 3 && isMyDept(resource.data.department) && getWeight() > getRoleWeight(resource.data.role))
      );
      
      allow delete: if isSignedIn() && (getWeight() >= 4 && userId != request.auth.uid);
    }

    // -------------------------
    // PROJECTS
    // -------------------------

    match /projects/{projectId} {
      allow read: if isSignedIn() && (
        getWeight() >= 4 || 
        resource.data.createdBy == request.auth.uid || 
        request.auth.uid in resource.data.assignedUsers ||
        (getWeight() >= 2 && isMyDept(resource.data.department))
      );
      allow create: if isSignedIn() && getWeight() >= 3;
      allow update: if isSignedIn() && (
        getWeight() >= 4 ||
        resource.data.createdBy == request.auth.uid ||
        (getWeight() >= 3 && isMyDept(resource.data.department))
      );
      allow delete: if isSignedIn() && (getWeight() >= 4 || resource.data.createdBy == request.auth.uid);
    }

    // -------------------------
    // TASKS
    // -------------------------

    match /tasks/{taskId} {
      allow read: if isSignedIn() && (
        resource.data.assignedTo == request.auth.uid || 
        resource.data.createdBy == request.auth.uid || 
        getWeight() >= 4 ||
        (getWeight() >= 2 && isMyDept(resource.data.assignedToDepartment))
      );
      allow create: if isSignedIn() && getWeight() >= 2;
      allow update: if isSignedIn() && (
        resource.data.assignedTo == request.auth.uid || 
        resource.data.createdBy == request.auth.uid || 
        getWeight() >= 3
      );
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || getWeight() >= 4);
    }

    // -------------------------
    // WORK LOGS
    // -------------------------

    match /work_logs/{logId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        getWeight() >= 4 || 
        (getWeight() >= 3 && isMyDept(resource.data.department))
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
