
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      let roleKey = role.replace(" ", "_");
      return exists(/databases/$(database)/documents/user_roles_$(roleKey)/$(request.auth.uid));
    }

    function getWeight() {
      return hasRole('Super Admin') ? 5 :
             hasRole('Admin') ? 4 :
             hasRole('Manager') ? 3 :
             hasRole('Team Lead') ? 2 : 1;
    }

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMyDept(dept) {
      let myDept = getUser().department;
      return myDept == dept || (myDept == 'Default' && dept == 'General') || (myDept == 'General' && dept == 'Default');
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (getWeight() >= 2 || request.auth.uid == userId);
      allow create: if isSignedIn() && (request.auth.uid == userId || getWeight() >= 4);
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && request.resource.data.role == resource.data.role) ||
        getWeight() >= 4 ||
        (getWeight() == 3 && isMyDept(resource.data.department))
      );
      allow delete: if isSignedIn() && getWeight() >= 4;
    }

    match /projects/{projectId} {
      allow read: if isSignedIn() && (
        getWeight() >= 4 ||
        (getWeight() >= 2 && isMyDept(resource.data.department)) ||
        (resource.data.assignedTo != null && request.auth.uid in resource.data.assignedTo)
      );
      allow create: if isSignedIn() && getWeight() >= 3;
      allow update: if isSignedIn() && (getWeight() >= 3 && isMyDept(resource.data.department));
      allow delete: if isSignedIn() && getWeight() >= 4;
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn() && (
        resource.data.assignedTo == request.auth.uid ||
        resource.data.createdBy == request.auth.uid ||
        getWeight() >= 4 ||
        (getWeight() >= 2 && isMyDept(resource.data.assignedToDepartment))
      );
      allow create: if isSignedIn() && getWeight() >= 2;
      allow update: if isSignedIn() && (
        resource.data.assignedTo == request.auth.uid ||
        resource.data.createdBy == request.auth.uid ||
        getWeight() >= 3
      );
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || getWeight() >= 4);
    }

    match /sub_tasks/{subTaskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && getWeight() >= 1;
      allow update, delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || getWeight() >= 3);
    }

    match /work_logs/{logId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        getWeight() >= 4 ||
        (getWeight() >= 3 && isMyDept(resource.data.department))
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /attendance/{id} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        getWeight() >= 4 ||
        (getWeight() >= 2 && isMyDept(resource.data.department))
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /leave_requests/{id} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        getWeight() >= 4 ||
        (getWeight() >= 2 && isMyDept(resource.data.department))
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || getWeight() >= 3);
    }

    match /user_roles_Super_Admin/{uid} { allow read, write: if isSignedIn() && getWeight() == 5; }
    match /user_roles_Admin/{uid} { allow read, write: if isSignedIn() && (getWeight() >= 4 || request.auth.uid == uid); }
    match /user_roles_Manager/{uid} { allow read, write: if isSignedIn() && (getWeight() >= 3 || request.auth.uid == uid); }
    match /user_roles_Team_Lead/{uid} { allow read, write: if isSignedIn() && (getWeight() >= 2 || request.auth.uid == uid); }
    match /user_roles_Employee/{uid} { allow read, write: if isSignedIn() && (getWeight() >= 1 || request.auth.uid == uid); }
  }
}
