
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData(uid) {
      let path = /databases/$(database)/documents/users/$(uid);
      return exists(path) ? get(path).data : {"role": "Employee", "department": "General"};
    }

    function isRole(role) {
      return getUserData(request.auth.uid).role == role;
    }

    function getLevel(role) {
      return role == 'Super Admin' ? 5 :
             role == 'Admin' ? 4 :
             role == 'Manager' ? 3 :
             role == 'Team Lead' ? 2 : 1;
    }

    function getMyWeight() {
      return getLevel(getUserData(request.auth.uid).role);
    }

    function isMyDept(dept) {
      return getUserData(request.auth.uid).department == dept;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && getMyWeight() >= 2;
      allow create: if isSignedIn() && (request.auth.uid == userId || getMyWeight() >= 4);
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && request.resource.data.role == resource.data.role) ||
        getMyWeight() >= 4 ||
        (getMyWeight() == 3 && isMyDept(resource.data.department))
      );
      allow delete: if isSignedIn() && getMyWeight() >= 4;
    }

    match /projects/{projectId} {
      allow read: if isSignedIn() && (
        getMyWeight() >= 4 ||
        (getMyWeight() >= 2 && isMyDept(resource.data.department)) ||
        (resource.data.assignedTo != null && request.auth.uid in resource.data.assignedTo)
      );
      allow create: if isSignedIn() && getMyWeight() >= 3;
      allow update: if isSignedIn() && (getMyWeight() >= 3 && isMyDept(resource.data.department));
      allow delete: if isSignedIn() && getMyWeight() >= 4;
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn() && (
        resource.data.assignedTo == request.auth.uid ||
        resource.data.createdBy == request.auth.uid ||
        getMyWeight() >= 4 ||
        (getMyWeight() >= 2 && isMyDept(resource.data.assignedToDepartment))
      );
      allow create: if isSignedIn() && getMyWeight() >= 2;
      allow update: if isSignedIn() && (
        resource.data.assignedTo == request.auth.uid ||
        resource.data.createdBy == request.auth.uid ||
        getMyWeight() >= 3
      );
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || getMyWeight() >= 4);
    }

    match /sub_tasks/{subTaskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && getMyWeight() >= 1;
      allow update, delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || getMyWeight() >= 3);
    }

    match /work_logs/{logId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        getMyWeight() >= 4 ||
        (getMyWeight() >= 3 && isMyDept(resource.data.department))
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /attendance/{id} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        getMyWeight() >= 4 ||
        (getMyWeight() >= 3 && isMyDept(resource.data.department))
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /leave_requests/{id} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        getMyWeight() >= 4 ||
        (getMyWeight() >= 3 && isMyDept(resource.data.department))
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || getMyWeight() >= 3);
    }

    match /user_roles_Super_Admin/{uid} { allow read, write: if isSignedIn() && getMyWeight() == 5; }
    match /user_roles_Admin/{uid} { allow read, write: if isSignedIn() && (getMyWeight() >= 4 || request.auth.uid == uid); }
    match /user_roles_Manager/{uid} { allow read, write: if isSignedIn() && (getMyWeight() >= 3 || request.auth.uid == uid); }
    match /user_roles_Team_Lead/{uid} { allow read, write: if isSignedIn() && (getMyWeight() >= 2 || request.auth.uid == uid); }
    match /user_roles_Employee/{uid} { allow read, write: if isSignedIn() && (getMyWeight() >= 1 || request.auth.uid == uid); }
  }
}
