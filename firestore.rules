
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------
    // Helper Functions
    // -------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : null;
    }

    function getRole() {
      let data = getUserData();
      return data != null ? data.role : "None";
    }

    function getWeight() {
      let role = getRole();
      return role == "Super Admin" ? 5 :
             role == "Admin" ? 4 :
             role == "Manager" ? 3 :
             role == "Team Lead" ? 2 : 
             role == "Employee" ? 1 : 0;
    }

    function isMyDept(dept) {
      let data = getUserData();
      return data != null && data.department == dept;
    }

    // -------------------------
    // USERS
    // -------------------------

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && getWeight() >= 2;
      allow create: if isSignedIn() && (request.auth.uid == userId || getWeight() >= 4);
      allow update: if isSignedIn() && (request.auth.uid == userId || getWeight() >= 4 || (getWeight() == 3 && isMyDept(resource.data.department)));
      allow delete: if isSignedIn() && getWeight() >= 4;
    }

    // -------------------------
    // PROJECTS
    // -------------------------

    match /projects/{projectId} {
      // NEW REQUIREMENTS:
      // Read: Authenticated AND (Creator OR in assignedUsers OR Admin+)
      allow read: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid || 
        request.auth.uid in resource.data.assignedUsers ||
        getWeight() >= 4
      );
      
      // Create: Any authenticated user
      allow create: if isSignedIn();
      
      // Update/Delete: Only the creator
      allow update, delete: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid
      );
    }

    // -------------------------
    // TASKS
    // -------------------------

    match /tasks/{taskId} {
      allow read: if isSignedIn() && (
        resource.data.assignedTo == request.auth.uid || 
        resource.data.createdBy == request.auth.uid || 
        getWeight() >= 4 ||
        (getWeight() >= 2 && isMyDept(resource.data.assignedToDepartment))
      );
      allow create: if isSignedIn() && getWeight() >= 2;
      allow update: if isSignedIn() && (
        resource.data.assignedTo == request.auth.uid || 
        resource.data.createdBy == request.auth.uid || 
        getWeight() >= 3
      );
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || getWeight() >= 4);
    }

    // -------------------------
    // SUB TASKS
    // -------------------------

    match /sub_tasks/{subTaskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || getWeight() >= 3);
    }

    // -------------------------
    // WORK LOGS
    // -------------------------

    match /work_logs/{logId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        getWeight() >= 4 || 
        (getWeight() >= 3 && isMyDept(resource.data.department))
      );
      
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // -------------------------
    // ATTENDANCE
    // -------------------------

    match /attendance/{id} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        getWeight() >= 3 || 
        (getWeight() >= 2 && isMyDept(resource.data.department))
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || getWeight() >= 3);
    }

    // -------------------------
    // LEAVE REQUESTS
    // -------------------------

    match /leave_requests/{id} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        getWeight() >= 3 || 
        (getWeight() >= 2 && isMyDept(resource.data.department))
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || getWeight() >= 3);
    }
  }
}
