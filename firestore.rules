
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getLevel(role) {
      return role == 'Super Admin' ? 5 :
             role == 'Admin' ? 4 :
             role == 'Manager' ? 3 :
             role == 'Team Lead' ? 2 : 1;
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function getMyWeight() {
      let myData = getUserData(request.auth.uid);
      return myData != null ? getLevel(myData.role) : 0;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && getMyWeight() >= 2;
      allow create: if isSignedIn() && (request.auth.uid == userId || getMyWeight() > getLevel(request.resource.data.role));
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && request.resource.data.role == resource.data.role) ||
        getMyWeight() > getLevel(resource.data.role)
      );
      allow delete: if isSignedIn() && getMyWeight() > getLevel(resource.data.role);
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        getMyWeight() >= 4 ||
        (getMyWeight() >= 2 && resource.data.department == getUserData(request.auth.uid).department)
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (request.resource.data.userId == request.auth.uid || getMyWeight() >= 3);
    }

    match /leave_requests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        getMyWeight() >= 4 ||
        (getMyWeight() >= 2 && resource.data.department == getUserData(request.auth.uid).department)
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        (getMyWeight() >= 3 && resource.data.department == getUserData(request.auth.uid).department) ||
        getMyWeight() == 5
      );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid && resource.data.status == 'Pending';
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn() && (
        resource.data.assignedToId == request.auth.uid ||
        resource.data.assignedById == request.auth.uid ||
        getMyWeight() >= 4 ||
        (getMyWeight() >= 2 && resource.data.assignedToDepartment == getUserData(request.auth.uid).department)
      );
      allow create: if isSignedIn() && getMyWeight() >= 2;
      allow update: if isSignedIn() && (
        resource.data.assignedToId == request.auth.uid ||
        resource.data.assignedById == request.auth.uid ||
        getMyWeight() >= 3 ||
        (getMyWeight() >= 2 && resource.data.assignedToDepartment == getUserData(request.auth.uid).department)
      );
      allow delete: if isSignedIn() && (resource.data.assignedById == request.auth.uid || getMyWeight() >= 4);
    }

    match /user_roles_Super_Admin/{uid} { allow read, write: if isSignedIn() && getMyWeight() == 5; }
    match /user_roles_Admin/{uid} { allow read, write: if isSignedIn() && (getMyWeight() >= 4 || request.auth.uid == uid); }
    match /user_roles_Manager/{uid} { allow read, write: if isSignedIn() && (getMyWeight() >= 3 || request.auth.uid == uid); }
    match /user_roles_Team_Lead/{uid} { allow read, write: if isSignedIn() && (getMyWeight() >= 2 || request.auth.uid == uid); }
    match /user_roles_Employee/{uid} { allow read, write: if isSignedIn() && (getMyWeight() >= 2 || request.auth.uid == uid); }
  }
}
