rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES - ROBUST RBAC HIERARCHY
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Robust role check: Checks both the DBAC collection AND the user profile fallback
    function hasRole(roleName) {
      let roleDoc = roleName.lower().replace(" ", "_");
      return isSignedIn() && (
        exists(/databases/$(database)/documents/user_roles_$(roleDoc)/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == roleName)
      );
    }

    function isSuperAdmin() { return hasRole('Super Admin'); }
    function isAdmin() { return isSuperAdmin() || hasRole('Admin'); }
    function isManager() { return isAdmin() || hasRole('Manager'); }
    function isTeamLead() { return isManager() || hasRole('Team Lead'); }

    // Hierarchy Logic for Creation (Checks incoming data)
    function canCreateRole(targetRole) {
      return isSuperAdmin() || 
             (isAdmin() && targetRole != 'Super Admin') ||
             (isManager() && (targetRole == 'Team Lead' || targetRole == 'Employee')) ||
             (isTeamLead() && targetRole == 'Employee');
    }

    // Hierarchy Logic for Management (Checks existing data)
    function canManageTarget(targetUserId) {
      // If we can't see the target, we can't manage them. 
      // This helper is used in update/delete.
      let target = get(/databases/$(database)/documents/users/$(targetUserId)).data;
      return isSuperAdmin() || 
             (isAdmin() && target.role != 'Super Admin') ||
             (isManager() && (target.role == 'Team Lead' || target.role == 'Employee')) ||
             (isTeamLead() && target.role == 'Employee');
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      // Users can always read their own profile. Admins+ can read based on hierarchy.
      allow get: if isOwner(userId) || isTeamLead();
      allow list: if isTeamLead();
      
      // Allow self-creation (registration) OR administrative creation based on hierarchy
      allow create: if isOwner(userId) || canCreateRole(request.resource.data.role);
      
      // Allow self-update OR administrative update
      allow update: if isOwner(userId) || canManageTarget(userId);
      
      // Only Admins and above can delete, respecting hierarchy
      allow delete: if isAdmin() && canManageTarget(userId);
    }

    // Role Assignment Collections (DBAC)
    // These are critical for exists() checks in rules.
    match /user_roles_super_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isSuperAdmin();
    }
    match /user_roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    match /user_roles_manager/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /user_roles_team_lead/{userId} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }
    match /user_roles_employee/{userId} {
      allow read: if isSignedIn();
      allow write: if isTeamLead();
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      // Only Team Leads and above can create tasks
      allow create: if isTeamLead();
      // Owners can update (to complete), or assigners/leads can update
      allow update: if isOwner(resource.data.assignedToId) || isTeamLead();
      // Admins or the original assigner can delete
      allow delete: if isAdmin() || (resource != null && resource.data.assignedById == request.auth.uid);
    }

    match /roles/{roleId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
    match /departments/{departmentId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
  }
}