rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES
     * Optimized for Role-Based Access Control (RBAC).
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role Checks (DBAC Pattern)
    // We use exists() to check for the presence of a document in role-specific collections.
    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/user_roles_super_admin/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/user_roles_admin/$(request.auth.uid));
    }

    function isManager() {
      return isSignedIn() && exists(/databases/$(database)/documents/user_roles_manager/$(request.auth.uid));
    }

    function isTeamLead() {
      return isSignedIn() && exists(/databases/$(database)/documents/user_roles_team_lead/$(request.auth.uid));
    }

    // Hierarchy Checks
    function isSubordinate(managerChain) {
      return isSignedIn() && request.auth.uid in managerChain;
    }

    function isHigherAuthority() {
      return isSuperAdmin() || isAdmin();
    }

    // --- COLLECTION RULES ---

    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    match /departments/{departmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    match /users/{userId} {
      // Allow read if owner, admin, or manager of this user
      allow get: if isOwner(userId) || isHigherAuthority() || (resource != null && isSubordinate(resource.data.managerChainIds));
      allow list: if isSignedIn();
      
      // Allow creation if the user is setting up their own account (first time) or if an admin is doing it
      allow create: if isOwner(userId) || isHigherAuthority();
      
      // Allow update if owner, admin, or manager
      allow update: if isOwner(userId) || isHigherAuthority() || (resource != null && isSubordinate(resource.data.managerChainIds));
      
      allow delete: if isSuperAdmin();
    }

    // Role Assignment Collections (DBAC)
    // These collections simply track UID existence to grant permissions.
    match /user_roles_super_admin/{userId} {
      allow read: if isSignedIn();
      // Allow self-provisioning for development prototype, or admin management
      allow write: if isOwner(userId) || isSuperAdmin(); 
    }
    match /user_roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isSuperAdmin();
    }
    match /user_roles_manager/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isHigherAuthority();
    }
    match /user_roles_team_lead/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isHigherAuthority() || isManager();
    }
    match /user_roles_employee/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isHigherAuthority() || isManager() || isTeamLead();
    }

    match /tasks/{taskId} {
      function canManageTask() {
        return isHigherAuthority() || (resource != null && isSubordinate(resource.data.assignedToManagerChainIds)) || (resource != null && resource.data.assignedById == request.auth.uid);
      }

      allow get: if isSignedIn() && (resource != null && (resource.data.assignedToId == request.auth.uid || canManageTask()));
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource != null && (resource.data.assignedToId == request.auth.uid || canManageTask()));
      allow delete: if isSignedIn() && (resource != null && (isHigherAuthority() || resource.data.assignedById == request.auth.uid));
    }
  }
}