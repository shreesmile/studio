rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPERS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRoleLevel(role) {
      let r = role.lower();
      return r == 'super admin' ? 4 :
             r == 'admin' ? 3 :
             r == 'manager' ? 2 :
             r == 'team lead' ? 1 : 0;
    }

    function getMyLevel() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null && 'role' in userDoc.data ? getRoleLevel(userDoc.data.role) : -1;
    }

    function canManageTarget(targetRole) {
      return isSignedIn() && getMyLevel() > getRoleLevel(targetRole);
    }

    // --- RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && getMyLevel() >= 1; // Team Lead+ can view directory
      
      // Allow registration (self-service) or creation by superiors
      allow create: if (isSignedIn() && isOwner(userId)) || canManageTarget(request.resource.data.role);
      
      // Allow update if owner (but role must stay same) OR if superior
      allow update: if isSignedIn() && (
        (isOwner(userId) && request.resource.data.role == resource.data.role) || 
        canManageTarget(resource.data.role)
      );
      
      allow delete: if isSignedIn() && canManageTarget(resource.data.role);
    }

    match /tasks/{taskId} {
      function myDept() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department;
      }

      // Read rules aligned with the query filters in TaskManagement.tsx
      allow read: if isSignedIn() && (
        getMyLevel() >= 3 || // Admin+ can see all
        (getMyLevel() >= 1 && resource.data.assignedToDepartment == myDept()) || // Manager/Lead see team
        resource.data.assignedToId == request.auth.uid // Employee sees own
      );

      allow create: if isSignedIn() && (
        getMyLevel() >= 3 || // Admin+
        (getMyLevel() >= 1 && canManageTarget(request.resource.data.assignedToRole)) // Higher roles assign to lower
      );

      allow update: if isSignedIn() && (
        getMyLevel() >= 3 || 
        resource.data.assignedToId == request.auth.uid ||
        resource.data.assignedById == request.auth.uid
      );

      allow delete: if isSignedIn() && getMyLevel() >= 3;
    }

    // Role index collections for existence checks (optional but supported)
    match /user_roles_{role}/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && getMyLevel() >= 3;
    }
  }
}