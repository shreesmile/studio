
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPERS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getWeight(role) {
      return role == 'Super Admin' ? 5 :
             role == 'Admin' ? 4 :
             role == 'Manager' ? 3 :
             role == 'Team Lead' ? 2 : 1;
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function getMyWeight() {
      let myData = getUserData(request.auth.uid);
      return myData != null ? getWeight(myData.role) : 0;
    }

    function isSuperior(targetRole) {
      return getMyWeight() > getWeight(targetRole);
    }

    // --- RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && getMyWeight() >= 2;
      
      allow create: if isSignedIn() && (
        (request.auth.uid == userId) || 
        isSuperior(request.resource.data.role)
      );
      
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && request.resource.data.role == resource.data.role) ||
        isSuperior(resource.data.role)
      );
      
      allow delete: if isSignedIn() && isSuperior(resource.data.role);
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        getMyWeight() >= 4 ||
        (getMyWeight() >= 2 && resource.data.department == getUserData(request.auth.uid).department)
      );
      
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid ||
        getMyWeight() >= 3
      );
    }

    match /leave_requests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        getMyWeight() >= 4 ||
        (getMyWeight() >= 2 && resource.data.department == getUserData(request.auth.uid).department)
      );
      
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        (getMyWeight() >= 3 && resource.data.department == getUserData(request.auth.uid).department) ||
        (getMyWeight() == 5)
      );
      
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid && resource.data.status == 'Pending'
      );
    }
  }
}
