rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES
     * Optimized for Role-Based Access Control (RBAC).
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role Checks (DBAC Pattern with QAP Fallback)
    // We check for document existence (fast) or fallback to getting the user profile (slower but resilient).
    function hasRole(roleName) {
      let roleDoc = roleName.lower().replace(" ", "_");
      return isSignedIn() && (
        exists(/databases/$(database)/documents/user_roles_$(roleDoc)/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == roleName
      );
    }

    function isSuperAdmin() {
      return hasRole('Super Admin');
    }

    function isAdmin() {
      return hasRole('Admin') || isSuperAdmin();
    }

    function isManager() {
      return hasRole('Manager') || isAdmin();
    }

    function isTeamLead() {
      return hasRole('Team Lead') || isManager();
    }

    // Hierarchy Checks
    function isSubordinate(managerChain) {
      return isSignedIn() && request.auth.uid in managerChain;
    }

    function isHigherAuthority() {
      return isAdmin();
    }

    // --- COLLECTION RULES ---

    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    match /departments/{departmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    match /users/{userId} {
      // Allow read if owner, admin, or manager of this user
      allow get: if isOwner(userId) || isHigherAuthority() || (resource != null && resource.data.get('managerChainIds', []) != null && isSubordinate(resource.data.managerChainIds));
      allow list: if isSignedIn();
      
      // Allow creation/update if owner or admin
      allow create, update: if isOwner(userId) || isHigherAuthority();
      
      allow delete: if isSuperAdmin();
    }

    // Role Assignment Collections (DBAC)
    match /user_roles_super_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isSuperAdmin(); 
    }
    match /user_roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isSuperAdmin();
    }
    match /user_roles_manager/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }
    match /user_roles_team_lead/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isManager();
    }
    match /user_roles_employee/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isTeamLead();
    }

    match /tasks/{taskId} {
      function canManageTask() {
        return isAdmin() || (resource != null && resource.data.get('assignedToManagerChainIds', []) != null && isSubordinate(resource.data.assignedToManagerChainIds)) || (resource != null && resource.data.assignedById == request.auth.uid);
      }

      allow get: if isSignedIn() && (resource != null && (resource.data.assignedToId == request.auth.uid || canManageTask()));
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource != null && (resource.data.assignedToId == request.auth.uid || canManageTask()));
      allow delete: if isSignedIn() && (resource != null && (isAdmin() || resource.data.assignedById == request.auth.uid));
    }
  }
}