rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role checks based on existence in specific collections (DBAC)
    function isSuperAdmin() { return exists(/databases/$(database)/documents/user_roles_Super_Admin/$(request.auth.uid)); }
    function isAdmin() { return isSuperAdmin() || exists(/databases/$(database)/documents/user_roles_Admin/$(request.auth.uid)); }
    function isManager() { return isAdmin() || exists(/databases/$(database)/documents/user_roles_Manager/$(request.auth.uid)); }
    function isTeamLead() { return isManager() || exists(/databases/$(database)/documents/user_roles_Team_Lead/$(request.auth.uid)); }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function getMyData() {
      return getUserData(request.auth.uid);
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isTeamLead());
      allow list: if isSignedIn() && isTeamLead();
      
      // Allow registration (self) OR creation by Admin+
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
      
      // Allow update if owner (cannot change role) OR if managing subordinate
      allow update: if isSignedIn() && (
        (isOwner(userId) && request.resource.data.role == resource.data.role) || 
        isSuperAdmin() ||
        (isAdmin() && resource.data.role != 'Super Admin') ||
        (isManager() && (resource.data.role == 'Team Lead' || resource.data.role == 'Employee'))
      );
      
      allow delete: if isSignedIn() && (
        isSuperAdmin() || 
        (isAdmin() && resource.data.role != 'Super Admin' && resource.data.role != 'Admin')
      );
    }

    match /tasks/{taskId} {
      function canViewTask(taskData) {
        let myProfile = getMyData();
        return isSuperAdmin() ||
               (isAdmin() && taskData.assignedByRole != 'Super Admin') ||
               (isManager() && taskData.assignedToDepartment == myProfile.department) ||
               (isTeamLead() && taskData.assignedToDepartment == myProfile.department) ||
               (taskData.assignedToId == request.auth.uid);
      }

      allow read: if isSignedIn() && canViewTask(resource.data);
      
      // Strict hierarchical task creation
      allow create: if isSignedIn() && (
        isSuperAdmin() || 
        (isAdmin() && request.resource.data.assignedToRole != 'Super Admin') ||
        (isManager() && (request.resource.data.assignedToRole == 'Team Lead' || request.resource.data.assignedToRole == 'Employee')) ||
        (isTeamLead() && request.resource.data.assignedToRole == 'Employee')
      );
      
      allow update: if isSignedIn() && (
        isSuperAdmin() || 
        (resource.data.assignedToId == request.auth.uid) || 
        isAdmin()
      );
      
      allow delete: if isSignedIn() && (isSuperAdmin() || isAdmin());
    }

    // Role Assignment Collections (DBAC)
    match /user_roles_Super_Admin/{userId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
    match /user_roles_Admin/{userId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
    match /user_roles_Manager/{userId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /user_roles_Team_Lead/{userId} { allow read: if isSignedIn(); allow write: if isManager(); }
    match /user_roles_Employee/{userId} { allow read: if isSignedIn(); allow write: if isTeamLead(); }

    match /roles/{roleId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
    match /departments/{departmentId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
  }
}