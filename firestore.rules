rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES - ROBUST RBAC HIERARCHY
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getRole() {
      let data = getUserData();
      return data != null && 'role' in data ? data.role : 'Employee';
    }

    function roleToLevel(role) {
      let r = role.lower();
      return r == 'super admin' ? 100 :
             r == 'admin' ? 80 :
             r == 'manager' ? 60 :
             r == 'team lead' ? 40 : 20;
    }

    function hasRole(roleName) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/user_roles_$(roleName.replace(' ', '_'))/$(request.auth.uid)) ||
        getRole() == roleName
      );
    }

    function isSuperAdmin() { return hasRole('Super Admin'); }
    function isAdmin() { return isSuperAdmin() || hasRole('Admin'); }
    function isManager() { return isAdmin() || hasRole('Manager'); }
    function isTeamLead() { return isManager() || hasRole('Team Lead'); }

    function canManageTarget(targetRole) {
      let myRole = getRole();
      return (roleToLevel(myRole) > roleToLevel(targetRole)) || (myRole == 'Super Admin');
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isTeamLead());
      allow list: if isTeamLead();
      
      // Allow initial profile creation for any authenticated user
      allow create: if isSignedIn();
      
      // Allow update if owner (but cannot change role) OR if managing a subordinate
      allow update: if isSignedIn() && (
        (isOwner(userId) && request.resource.data.role == resource.data.role) || 
        canManageTarget(resource.data.role)
      );
      
      allow delete: if isSignedIn() && canManageTarget(resource.data.role);
    }

    match /tasks/{taskId} {
      function canViewTask(taskData) {
        let myProfile = getUserData();
        return isSuperAdmin() ||
               (isAdmin() && taskData.assignedByRole != 'Super Admin') ||
               (isManager() && taskData.assignedToDepartment == myProfile.department) ||
               (isTeamLead() && taskData.assignedToDepartment == myProfile.department) ||
               (taskData.assignedToId == request.auth.uid);
      }

      allow read: if isSignedIn() && canViewTask(resource.data);
      
      allow create: if isSignedIn() && (
        isSuperAdmin() || 
        canManageTarget(request.resource.data.assignedToRole)
      );
      
      allow update: if isSignedIn() && (
        isSuperAdmin() || 
        (resource.data.assignedToId == request.auth.uid) || 
        canManageTarget(resource.data.assignedToRole)
      );
      
      allow delete: if isSignedIn() && (
        isSuperAdmin() || 
        canManageTarget(resource.data.assignedToRole)
      );
    }

    // Role Assignment Collections (DBAC)
    match /user_roles_Super_Admin/{userId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
    match /user_roles_Admin/{userId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
    match /user_roles_Manager/{userId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /user_roles_Team_Lead/{userId} { allow read: if isSignedIn(); allow write: if isManager(); }
    match /user_roles_Employee/{userId} { allow read: if isSignedIn(); allow write: if isTeamLead(); }

    match /roles/{roleId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
    match /departments/{departmentId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
  }
}