rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES - HIERARCHICAL RBAC
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasRole(roleName) {
      let roleDoc = roleName.lower().replace(" ", "_");
      return isSignedIn() && (
        exists(/databases/$(database)/documents/user_roles_$(roleDoc)/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == roleName)
      );
    }

    // Role Definition Helpers
    function isSuperAdmin() { return hasRole('Super Admin'); }
    function isAdmin() { return isSuperAdmin() || hasRole('Admin'); }
    function isManager() { return isAdmin() || hasRole('Manager'); }
    function isTeamLead() { return isManager() || hasRole('Team Lead'); }

    // Management Hierarchy Logic for CREATE (Checks incoming data)
    function canCreateRole(targetRole) {
      return isSuperAdmin() || 
             (isAdmin() && targetRole != 'Super Admin') ||
             (isManager() && (targetRole == 'Team Lead' || targetRole == 'Employee')) ||
             (isTeamLead() && targetRole == 'Employee');
    }

    // Management Hierarchy Logic for UPDATE/DELETE (Checks existing data)
    function canManageExistingUser(targetUserId) {
      let targetData = get(/databases/$(database)/documents/users/$(targetUserId)).data;
      let targetRole = targetData.role;
      
      return isSuperAdmin() || 
             (isAdmin() && targetRole != 'Super Admin') ||
             (isManager() && (targetRole == 'Team Lead' || targetRole == 'Employee')) ||
             (isTeamLead() && targetRole == 'Employee');
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || canManageExistingUser(userId);
      allow list: if isTeamLead();
      
      // Allow self-registration OR allowed hierarchy creation
      allow create: if isOwner(userId) || canCreateRole(request.resource.data.role);
      allow update: if isOwner(userId) || canManageExistingUser(userId);
      allow delete: if isSuperAdmin() || (isAdmin() && canManageExistingUser(userId));
    }

    // Role Assignment Collections (DBAC)
    match /user_roles_super_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isSuperAdmin();
    }
    match /user_roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    match /user_roles_manager/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /user_roles_team_lead/{userId} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }
    match /user_roles_employee/{userId} {
      allow read: if isSignedIn();
      allow write: if isTeamLead();
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isTeamLead();
      allow update: if isOwner(resource.data.assignedToId) || isTeamLead();
      allow delete: if isAdmin() || (resource != null && resource.data.assignedById == request.auth.uid);
    }

    match /roles/{roleId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
    match /departments/{departmentId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
  }
}