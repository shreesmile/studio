rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPERS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRoleLevel(role) {
      // Use exact strings to avoid case-conversion hallucinations
      return role == 'Super Admin' ? 4 :
             role == 'Admin' ? 3 :
             role == 'Manager' ? 2 :
             role == 'Team Lead' ? 1 : 0;
    }

    function getMyLevel() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null && 'role' in userDoc.data ? getRoleLevel(userDoc.data.role) : -1;
    }

    function canManageTarget(targetRole) {
      return isSignedIn() && getMyLevel() > getRoleLevel(targetRole);
    }

    // --- RULES ---

    match /users/{userId} {
      // Allow any signed-in user to see any profile (for directory/assignments)
      allow get: if isSignedIn();
      
      // Only Team Leads and above can list the entire directory
      allow list: if isSignedIn() && getMyLevel() >= 1;
      
      // Allow creation by self (registration) or by a superior
      allow create: if isSignedIn() && (isOwner(userId) || canManageTarget(request.resource.data.role));
      
      // Allow update if owner (but role must stay same) OR if superior
      allow update: if isSignedIn() && (
        (isOwner(userId) && request.resource.data.role == resource.data.role) || 
        canManageTarget(resource.data.role)
      );
      
      // Only superiors can delete
      allow delete: if isSignedIn() && canManageTarget(resource.data.role);
    }

    match /tasks/{taskId} {
      function myData() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      }

      // Read rules: 
      // 1. Admin+ sees all
      // 2. Managers/Leads see their department
      // 3. Employees see their own tasks
      allow read: if isSignedIn() && (
        getMyLevel() >= 3 || 
        (getMyLevel() >= 1 && resource.data.assignedToDepartment == myData().department) ||
        resource.data.assignedToId == request.auth.uid ||
        resource.data.assignedById == request.auth.uid
      );

      // Create rules: Higher roles assign to lower roles
      allow create: if isSignedIn() && (
        getMyLevel() >= 3 || 
        (getMyLevel() >= 1 && getMyLevel() > getRoleLevel(request.resource.data.assignedToRole))
      );

      // Update rules: Creator, Assignee, or Admin+
      allow update: if isSignedIn() && (
        getMyLevel() >= 3 || 
        resource.data.assignedToId == request.auth.uid ||
        resource.data.assignedById == request.auth.uid
      );

      allow delete: if isSignedIn() && getMyLevel() >= 3;
    }

    // Role index collections for existence checks
    match /user_roles_{role}/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && getMyLevel() >= 3;
    }
  }
}