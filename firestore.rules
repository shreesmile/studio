
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES - ROBUST RBAC HIERARCHY
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasRole(roleName) {
      let roleKey = roleName.toLower().replace(" ", "_");
      return isSignedIn() && (
        exists(/databases/$(database)/documents/user_roles_$(roleKey)/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == roleName)
      );
    }

    function isSuperAdmin() { return hasRole('Super Admin'); }
    function isAdmin() { return isSuperAdmin() || hasRole('Admin'); }
    function isManager() { return isAdmin() || hasRole('Manager'); }
    function isTeamLead() { return isManager() || hasRole('Team Lead'); }

    // Logic to check if a user can manage a target role
    function canManageTargetRole(targetRole) {
      return isSuperAdmin() || 
             (isAdmin() && targetRole != 'Super Admin') ||
             (isManager() && (targetRole == 'Team Lead' || targetRole == 'Employee')) ||
             (isTeamLead() && targetRole == 'Employee');
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isTeamLead());
      allow list: if isTeamLead();
      
      allow create: if isSignedIn() && (
        isOwner(userId) || 
        canManageTargetRole(request.resource.data.role)
      );
      
      allow update: if isSignedIn() && (
        isOwner(userId) || 
        (canManageTargetRole(resource.data.role) && canManageTargetRole(request.resource.data.role))
      );
      
      allow delete: if isSignedIn() && (
        isAdmin() && canManageTargetRole(resource.data.role)
      );
    }

    // Role Assignment Collections (DBAC)
    match /user_roles_super_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    match /user_roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    match /user_roles_manager/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /user_roles_team_lead/{userId} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }
    match /user_roles_employee/{userId} {
      allow read: if isSignedIn();
      allow write: if isTeamLead();
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isTeamLead();
      allow update: if isSignedIn() && (isOwner(resource.data.assignedToId) || isTeamLead());
      allow delete: if isSignedIn() && (isAdmin() || (resource != null && resource.data.assignedById == request.auth.uid));
    }

    match /roles/{roleId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
    match /departments/{departmentId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
  }
}
