rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES - STRICT HIERARCHICAL RBAC
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    function hasRole(roleName) {
      let roleDoc = roleName.lower().replace(" ", "_");
      return isSignedIn() && (
        exists(/databases/$(database)/documents/user_roles_$(roleDoc)/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == roleName)
      );
    }

    // Role Definition Helpers
    function isSuperAdmin() { return hasRole('Super Admin'); }
    function isAdmin() { return isSuperAdmin() || hasRole('Admin'); }
    function isManager() { return isAdmin() || hasRole('Manager'); }
    function isTeamLead() { return isManager() || hasRole('Team Lead'); }
    function isEmployee() { return hasRole('Employee'); }

    // Management Hierarchy Logic
    // Validates if the request.auth.uid can perform actions on targetUserId
    function canManageUser(targetUserId) {
      let callerRole = getRole(request.auth.uid);
      let targetRole = getRole(targetUserId);
      
      return isSuperAdmin() || 
             (hasRole('Admin') && targetRole != 'Super Admin') ||
             (hasRole('Manager') && (targetRole == 'Team Lead' || targetRole == 'Employee')) ||
             (hasRole('Team Lead') && targetRole == 'Employee');
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || canManageUser(userId);
      allow list: if isSignedIn();
      
      // Profiles can be created during sign-up (isOwner) or by authorized managers
      allow create: if isOwner(userId) || isAdmin();
      
      allow update: if isOwner(userId) || canManageUser(userId);
      
      // Only Super Admins can truly delete, or Admins if it's not a Super Admin
      allow delete: if isSuperAdmin() || (hasRole('Admin') && getRole(userId) != 'Super Admin');
    }

    // Role Assignment Collections (DBAC)
    match /user_roles_super_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin(); 
    }
    match /user_roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    match /user_roles_manager/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /user_roles_team_lead/{userId} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }
    match /user_roles_employee/{userId} {
      allow read: if isSignedIn();
      allow write: if isTeamLead();
    }

    match /tasks/{taskId} {
      // Employees see only their tasks. Managers/Leads see tasks they assigned or assigned to their reports.
      allow read: if isSignedIn();
      
      // Employees cannot create tasks. Team Leads and above can.
      allow create: if isTeamLead();
      
      // Owners can update status. Assigners or higher roles can update details.
      allow update: if isSignedIn();
      
      // Only Admins or the person who assigned it can delete.
      allow delete: if isAdmin() || (resource != null && resource.data.assignedById == request.auth.uid);
    }

    match /roles/{roleId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
    match /departments/{departmentId} { allow read: if isSignedIn(); allow write: if isSuperAdmin(); }
  }
}